    "context-window",
    "token-cost",
    "claude",
    "cli"
  ],
  "homepage": "https://github.com/anandsaini18/deadskills#readme",
  "bugs": {
    "url": "https://github.com/anandsaini18/deadskills/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anandsaini18/deadskills.git"
  },
  "license": "MIT",
  "author": "Mukul",
  "type": "module",
  "bin": {
    "deadskills": "dist/cli.js"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
